# python-llm 컨테이너(sangsangseoga-python 리포) 전용 값. backend의 .env.prod와 공유하지 않고
# 이 파일로 분리한다(DB 비밀번호 등 backend 전용 값이 이 컨테이너까지 넘어가지 않게 하기 위함).
# 실제 값 파일은 .env.python-llm으로 만들 것(gitignore됨).

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# 운영 프론트 도메인. 콤마로 여러 개 지정 가능 (예: https://app.example.com,https://www.example.com)
CORS_ALLOWED_ORIGINS=https://app.example.com
