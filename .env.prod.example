# EC2에서 docker-compose.prod.yml과 함께 쓰는 실제 값 파일은 .env.prod로 만들고(gitignore됨),
# 이 파일은 어떤 키가 필요한지 보여주는 템플릿이다. 값을 채워서 EC2에 .env.prod로 올릴 것.

# --- DB (RDS) ---
PROD_DB_HOST=your-rds-endpoint.ap-northeast-2.rds.amazonaws.com
PROD_DB_USERNAME=sangsangseoga
PROD_DB_PASSWORD=

# --- JWT ---
JWT_SECRET_KEY=

# --- 프론트엔드 도메인 (CORS, 메일 링크 등에 사용) ---
FRONTEND_URL=https://app.example.com

# --- 메일 (AWS SES SMTP 등) ---
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=no-reply@example.com

# --- AI (Gemini) ---
GEMINI_API_KEY=

# --- 파일 저장 (S3, EC2에 붙인 IAM Role이 자격증명을 대신하므로 액세스키는 여기 넣지 않는다) ---
STORAGE_TYPE=s3
S3_BUCKET=sangsangseoga-uploads
S3_REGION=ap-northeast-2
S3_PUBLIC_BASE_URL=https://d1234567890.cloudfront.net

# --- 파이썬 LLM 서버 (docker-compose.prod.yml이 자동으로 python-llm 서비스명으로 덮어씀) ---
# FASTAPI_BASE_URL=http://python-llm:8000
